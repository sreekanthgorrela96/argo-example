# Copy to .env in this directory (compose reads it automatically).
# Must match the group owning /var/run/docker.sock on the Docker host.
# Detect (any OS with Docker):
#   docker run --rm -v /var/run/docker.sock:/var/run/docker.sock alpine:3.20 stat -c '%g' /var/run/docker.sock
# Linux with docker group is often 999; Docker Desktop commonly reports 0 — always detect:
#   docker run --rm -v /var/run/docker.sock:/var/run/docker.sock alpine:3.20 stat -c '%g' /var/run/docker.sock
DOCKER_GID=0
